# API Configuration
BASE_URL=https://api.example.com/
CONNECT_TIMEOUT=30
READ_TIMEOUT=30

# App Configuration
APP_NAME=MyComposeProject
VERSION_NAME=1.0.0
VERSION_CODE=1

# Build Configuration
MIN_SDK=24
TARGET_SDK=36
COMPILE_SDK=36

# Debug Configuration
DEBUG_MODE=true
ENABLE_LOGGING=true

# Security (DO NOT COMMIT REAL VALUES)
API_KEY=your_api_key_here
SECRET_KEY=your_secret_key_here
